# Backend API URL Configuration
# =============================
# For laptop-only development:
# VITE_BACKEND_URL=http://localhost:3000
#
# For mobile testing (devices on same WiFi network):
# 1. Find your computer's local IP address:
#    - Windows: Open CMD and run: ipconfig | findstr "IPv4"
#    - Mac/Linux: Open Terminal and run: ifconfig | grep "inet "
# 2. Use that IP address in the URL below
#
# Example: If your IP is 192.168.1.100
# VITE_BACKEND_URL=http://192.168.1.100:3000
#
# IMPORTANT: Both laptop and mobile must be on the same WiFi network
VITE_BACKEND_URL=http://localhost:3000

# Mobile Experience Enhancement Feature Flags
# ===========================================
# Enable Progressive Web App features
VITE_ENABLE_PWA=true

# Enable offline mode and complaint drafting
VITE_ENABLE_PWA_OFFLINE=true

# Enable browser push notifications
VITE_ENABLE_PUSH_NOTIFICATIONS=true
