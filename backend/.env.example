# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/smart-city-grs

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Server Configuration
# ====================
PORT=3000

# Host configuration for mobile device support
# 0.0.0.0 allows connections from any network interface (required for mobile)
# 127.0.0.1 only allows localhost connections (laptop only)
HOST=0.0.0.0

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Roboflow API (for image validation)
ROBOFLOW_API_KEY=your_roboflow_api_key

# Node Environment
NODE_ENV=development
